# ── App ──
APP_NAME=marco
APP_URL=http://localhost:3000

# ── Supabase (valores reais em .env.local) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (classificação/extração = LIGHT; síntese = MODEL; embeddings p/ pgvector) ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_MODEL_LIGHT=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Telegram (token vira credencial no n8n, não na Vercel) ──
TELEGRAM_BOT_TOKEN=

# ── Google OAuth / Service Account (Gmail, Drive — Marcos 13/14) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SA_EMAIL=
GOOGLE_SA_PRIVATE_KEY=

# ── n8n ──
N8N_BASE_URL=https://workflowsmatriz.cassinweb.shop
N8N_WEBHOOK_SECRET=

# ── App security ──
APP_SECRET=
ALLOWED_USER_EMAIL=
